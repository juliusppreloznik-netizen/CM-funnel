{
  "name": "cm-funnel",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:worker\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:worker": "wrangler dev worker/src/index.ts --local",
    "build": "pnpm run build:client && pnpm run build:worker",
    "build:client": "vite build --config client/vite.config.ts",
    "build:worker": "wrangler deploy --dry-run --outdir dist/worker",
    "deploy": "pnpm run build:client && wrangler deploy",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "db:migrate": "wrangler d1 migrations apply cm-funnel-db",
    "db:migrate:local": "wrangler d1 migrations apply cm-funnel-db --local",
    "db:generate": "node scripts/generate-migration.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.90.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.22",
    "lucide-react": "^0.453.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.64.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "wouter": "^3.3.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250525.0",
    "@tailwindcss/vite": "^4.1.3",
    "@types/node": "^24.7.0",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.47",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.14",
    "typescript": "5.9.3",
    "vite": "^7.1.7",
    "wrangler": "^4.20.0"
  },
  "packageManager": "pnpm@10.4.1"
}
